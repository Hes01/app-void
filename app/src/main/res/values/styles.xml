<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Launcher: pantalla totalmente negra, sin chrome del sistema -->
    <style name="Theme.Void" parent="android:Theme.NoTitleBar.Fullscreen">
        <item name="android:windowBackground">@color/black</item>
        <item name="android:colorBackground">@color/black</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <!-- Configuración: dark, sin action bar, con UI mínima -->
    <style name="Theme.Void.Settings" parent="android:Theme.Holo.NoActionBar">
        <item name="android:windowBackground">@color/surface</item>
        <item name="android:colorBackground">@color/surface</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:listDivider">@null</item>
    </style>

</resources>
